# .env.example — shell env for DB tooling + dev app builds.
#
# Copy to .env (gitignored) and fill in the DEV values:
#     cp .env.example .env
#
# NOTE: the Flutter app does NOT read this file — it takes Supabase creds via
# --dart-define at build time (see lib/core/config/app_config.dart). This file
# is for (a) applying migrations from the shell and (b) a handy place to keep
# the dev values you paste into --dart-define.
#
# ⚠ SAFETY (per docs/ENVIRONMENT.md §3 + AUTONOMOUS_BRIEF §0):
#   - DEV project ONLY — ref jcuwfjyyqsjnmqxpqlbt.
#   - NEVER put prod creds (ref mgftoofmcnxfshtailgn) or the account-wide
#     SUPABASE_ACCESS_TOKEN in here.
#   - This file (.env) is gitignored; keep it that way.

# ── Required: applying migrations ────────────────────────────────────────────
# The dev project's Postgres connection string. Dashboard → dev project →
# Project Settings → Database → Connection string → URI (direct connection).
# Includes the DB password — fine in a gitignored .env.
#   psql "$DEV_DB_URL" -f docs/migrations/064_cs_ahts.sql
DEV_DB_URL=postgresql://postgres:[DEV_DB_PASSWORD]@db.jcuwfjyyqsjnmqxpqlbt.supabase.co:5432/postgres

# ── Dev app build creds (pass to `flutter run` via --dart-define) ────────────
# Dashboard → dev project → Project Settings → API.
SUPABASE_URL=https://jcuwfjyyqsjnmqxpqlbt.supabase.co
SUPABASE_ANON_KEY=[DEV_ANON_KEY]

# Dev service-role key — bypasses RLS (god-mode) on DEV ONLY. Never the prod one.
# Only needed for admin/seed scripts; omit if unused.
SUPABASE_SERVICE_ROLE=[DEV_SERVICE_ROLE_KEY]
